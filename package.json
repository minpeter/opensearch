{
  "$schema": "http://json.schemastore.org/package.json",
  "name": "opensearch-workspace",
  "private": true,
  "description": "Zero-config web search and page fetch for MCP clients",
  "license": "MIT",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/minpeter/opensearch"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "check": "turbo run check",
    "fix": "turbo run fix",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:release": "node --test scripts/tegami-config.test.mjs",
    "verify:published": "node scripts/verify-published-packages.mjs",
    "verify:packed": "node scripts/verify-packed-packages.mjs",
    "attw": "turbo run attw",
    "verify:edge": "turbo run verify:edge",
    "start": "pnpm --filter opensearch-mcp start",
    "tegami": "node scripts/tegami.mts",
    "version": "pnpm tegami version",
    "release": "pnpm build && pnpm tegami publish"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@biomejs/biome": "2.4.16",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.1.10",
    "tegami": "^1.2.5",
    "tsdown": "^0.22.8",
    "turbo": "^2.10.5",
    "typescript": "^7.0.2",
    "ultracite": "7.8.1",
    "vitest": "^4.1.10"
  }
}
