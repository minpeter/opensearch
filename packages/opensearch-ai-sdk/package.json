{
  "$schema": "http://json.schemastore.org/package.json",
  "name": "opensearch-ai-sdk",
  "version": "0.0.10",
  "description": "AI SDK tools for OpenSearch web search and page fetch",
  "keywords": [
    "ai",
    "ai-sdk",
    "fetch",
    "search",
    "websearch"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/minpeter/opensearch",
    "directory": "packages/opensearch-ai-sdk"
  },
  "type": "module",
  "types": "./out/index.d.ts",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./out/index.d.ts",
      "import": "./out/index.js"
    },
    "./node": {
      "types": "./out/node.d.ts",
      "import": "./out/node.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "out"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=json-summary",
    "attw": "attw --pack . --profile esm-only"
  },
  "peerDependencies": {
    "ai": "^6.0.0"
  },
  "dependencies": {
    "@minpeter/opensearch": "^0.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "ai": "7.0.30"
  }
}
